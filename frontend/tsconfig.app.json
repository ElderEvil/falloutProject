{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["src/vite-env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"],
      "@/core/*": ["./src/core/*"],
      "@/modules/*": ["./src/modules/*"]
    },

    "strict": true
  },
  "vueCompilerOptions": {
    "strictTemplates": true
  }
}
