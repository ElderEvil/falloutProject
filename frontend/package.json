{
  "name": "frontend",
  "version": "2.23.2",
  "private": true,
  "type": "module",
  "scripts": {
    "types:generate": "openapi-typescript http://localhost:8000/api/v1/openapi.json -o src/core/types/api.generated.ts",
    "dev": "pnpm types:generate && vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "test": "vp test",
    "test:run": "vp test run",
    "lint": "vp lint src",
    "lint:fix": "vp lint src --fix",
    "format": "vp fmt src",
    "format:check": "vp fmt src --check",
    "typecheck": "vue-tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@iconify/vue": "5.0.1",
    "@nuxt/ui": "^4.9.0",
    "@vueuse/core": "14.3.0",
    "@vueuse/motion": "3.0.3",
    "axios": "1.18.1",
    "dompurify": "3.4.12",
    "jwt-decode": "4.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "28.0.3",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.2.2",
    "vite-plus": "0.2.2",
    "vitest": "4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11.0.0 <12"
  },
  "packageManager": "pnpm@11.9.0"
}
